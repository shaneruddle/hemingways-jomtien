rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read so public visitors and server-side proxy can access menu images
      allow read: if true || request.auth != null;
      allow write: if request.auth != null && request.auth.token.email_verified == true;
    }
  }
}
