{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "A menu item with multi-language support.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "English name" },
        "name_chinese": { "type": "string", "description": "Chinese name" },
        "name_russian": { "type": "string", "description": "Russian name" },
        "name_thai": { "type": "string", "description": "Thai name" },
        "description": { "type": "string", "description": "English description" },
        "description_chinese": { "type": "string", "description": "Chinese description" },
        "description_russian": { "type": "string", "description": "Russian description" },
        "description_thai": { "type": "string", "description": "Thai description" },
        "price": { "type": "string", "description": "Price (can be a range or single value)" },
        "category": { "type": "string", "description": "Food category" },
        "image": { "type": "string", "description": "Image URL" },
        "published": { "type": "boolean", "description": "Whether the item is active" },
        "order": { "type": "integer", "description": "Display order" },
        "uid": { "type": "string", "description": "Creator UID" }
      },
      "required": ["name", "category", "price"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Application settings",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["key", "value"]
    },
    "Category": {
      "title": "Category",
      "description": "Menu category with custom display order.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Category name" },
        "order": { "type": "integer", "description": "Display order" },
        "uid": { "type": "string", "description": "Creator UID" }
      },
      "required": ["name", "order"]
    },
    "FinanceCategory": {
      "title": "Finance Category",
      "description": "Category for income, expense, or dividend.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Category name" },
        "type": { "type": "string", "description": "income, expense or dividend", "enum": ["income", "expense", "dividend"] },
        "uid": { "type": "string", "description": "Creator UID" }
      },
      "required": ["name", "type"]
    },
    "FinanceEntry": {
      "title": "Finance Entry",
      "description": "An income, expense, or dividend record.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "description": "income, expense or dividend", "enum": ["income", "expense", "dividend"] },
        "amount": { "type": "number", "description": "Amount in Baht" },
        "categoryId": { "type": "string", "description": "Reference to FinanceCategory" },
        "categoryName": { "type": "string", "description": "Category name for display" },
        "description": { "type": "string", "description": "Optional description" },
        "date": { "type": "string", "format": "date-time", "description": "Transaction date" },
        "createdBy": { "type": "string", "description": "User email or name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "uid": { "type": "string", "description": "Creator UID" }
      },
      "required": ["type", "amount", "categoryId", "date"]
    },
    "User": {
      "title": "User",
      "description": "User profile and permissions.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "description": "User role (admin, staff, etc.)", "enum": ["admin", "staff", "user"] },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" },
        "uid": { "type": "string", "description": "Firebase Auth UID" }
      },
      "required": ["email", "role", "uid"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Employee details and base salary.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "baseSalary": { "type": "number" },
        "position": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "bankBranch": { "type": "string" },
        "bankAccountNumber": { "type": "string" },
        "uid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "baseSalary", "position", "uid"]
    },
    "PayrollSummary": {
      "title": "Payroll Summary",
      "description": "Monthly payroll summary for an employee.",
      "type": "object",
      "properties": {
        "month": { "type": "string", "description": "YYYY-MM" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "position": { "type": "string" },
        "baseSalary": { "type": "number" },
        "advances": { "type": "number" },
        "deductions": { "type": "number" },
        "bonuses": { "type": "number" },
        "totalDue": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["month", "employeeId", "totalDue", "uid"]
    },
    "LoyaltyCustomer": {
      "title": "Loyalty Customer",
      "description": "Customer in the loyalty and wallet system.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "balance": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "mobile", "balance"]
    }
  },
  "firestore": {
    "/menu/{itemId}": {
      "schema": "MenuItem",
      "description": "Collection of menu items."
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "Collection of application settings"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of menu categories."
    },
    "/finance_categories/{categoryId}": {
      "schema": "FinanceCategory",
      "description": "Collection of finance categories."
    },
    "/finance_entries/{entryId}": {
      "schema": "FinanceEntry",
      "description": "Collection of income and expense entries."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of employees."
    },
    "/payroll_summaries/{summaryId}": {
      "schema": "PayrollSummary",
      "description": "Collection of monthly payroll summaries."
    },
    "/loyalty_customers/{customerId}": {
      "schema": "LoyaltyCustomer",
      "description": "Collection of loyalty customers."
    }
  }
}
